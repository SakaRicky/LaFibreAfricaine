# Local development (project Postgres cluster on port 5433 — see README)
DATABASE_URL=postgresql://lafibre@localhost:5433/lafibre
PORT=4000

# Auth — set a long random string in production (openssl rand -hex 32)
JWT_SECRET=change-me

# Cloudinary — CDN for product images (dashboard.cloudinary.com → API Keys).
# When unset, images fall back to local disk (media/) — fine for CI, not for production.
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Emails (optional — skipped gracefully when unset). Gmail app password works:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-gmail-app-password
# MAIL_FROM="La Fibre Africaine" <you@gmail.com>
